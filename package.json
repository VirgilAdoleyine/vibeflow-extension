{
  "name": "vibeflow-orch",
  "displayName": "VibeFlow Orch — AI Workflow Builder",
  "description": "Describe workflows in plain English. AI builds, runs, and self-heals Python automation scripts. By Virgil Junior Adoleyine 🇬🇭",
  "version": "2.0.4",
  "publisher": "vibeflow",
  "icon": "media/icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "AI",
    "Machine Learning",
    "Other"
  ],
  "keywords": [
    "workflow",
    "automation",
    "ai",
    "claude",
    "gemini",
    "python",
    "langchain",
    "vibeflow-orch",
    "orchestration"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/VirgilAdoleyine/vibeflow-orchension"
  },
  "activationEvents": [
    "onCommand:vibeflow-orch.open",
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "vibeflow-orch.open",
        "title": "VibeFlow: Open Workflow Builder",
        "icon": "$(zap)"
      },
      {
        "command": "vibeflow-orch.newWorkflow",
        "title": "VibeFlow: New Workflow from Prompt"
      },
      {
        "command": "vibeflow-orch.searchModels",
        "title": "VibeFlow: Search Best AI Models for Task"
      },
      {
        "command": "vibeflow-orch.checkRegulations",
        "title": "VibeFlow: Check Workflow Regulations"
      },
      {
        "command": "vibeflow-orch.generateFiles",
        "title": "VibeFlow: Generate .py + .env.local + README"
      },
      {
        "command": "vibeflow-orch.syncRepos",
        "title": "VibeFlow: Sync Cloud + Community Repos"
      },
      {
        "command": "vibeflow-orch.contributeRegGuard",
        "title": "VibeFlow: Contribute to RegGuard ⭐"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "vibeflow-orch.open",
          "group": "navigation",
          "when": "resourceExtname == .py || resourceExtname == .ts"
        }
      ]
    },
    "configuration": {
      "title": "VibeFlow",
      "properties": {
        "vibeflow-orch.openRouterKey": {
          "type": "string",
          "description": "Your OpenRouter API key. Get one at openrouter.ai",
          "secret": true
        },
        "vibeflow-orch.defaultModel": {
          "type": "string",
          "default": "anthropic/claude-sonnet-4-5",
          "description": "Default AI model (searched via Perplexity)"
        },
        "vibeflow-orch.perplexityKey": {
          "type": "string",
          "description": "Perplexity API key for model search + regulation scanning",
          "secret": true
        },
        "vibeflow-orch.e2bApiKey": {
          "type": "string",
          "description": "E2B sandbox API key",
          "secret": true
        },
        "vibeflow-orch.composioApiKey": {
          "type": "string",
          "description": "Composio API key for 400+ OAuth integrations",
          "secret": true
        },
        "vibeflow-orch.inngestSigningKey": {
          "type": "string",
          "description": "Inngest signing key",
          "secret": true
        },
        "vibeflow-orch.inngestEventKey": {
          "type": "string",
          "description": "Inngest event key",
          "secret": true
        },
        "vibeflow-orch.neonDatabaseUrl": {
          "type": "string",
          "description": "Neon Postgres database URL",
          "secret": true
        },
        "vibeflow-orch.upstashRedisUrl": {
          "type": "string",
          "description": "Upstash Redis URL",
          "secret": true
        },
        "vibeflow-orch.upstashRedisToken": {
          "type": "string",
          "description": "Upstash Redis token",
          "secret": true
        },
        "vibeflow-orch.userGitHubRepo": {
          "type": "string",
          "description": "Your personal/cloud GitHub repo URL (origin)"
        },
        "vibeflow-orch.communityGitRepo": {
          "type": "string",
          "description": "VibeFlow community repo URL"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.config.mjs --production && cd webview && npm run build",
    "watch": "node esbuild.config.mjs --watch",
    "watch:webview": "cd webview && npm run dev",
    "lint": "eslint src --ext ts",
    "package": "vsce package",
    "publish": "vsce publish && ovsx publish"
  },
  "dependencies": {
    "@langchain/openai": "^0.3.0",
    "langchain": "^0.3.0",
    "node-fetch": "^3.3.2",
    "posthog-node": "^5.29.1",
    "simple-git": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.24.0",
    "esbuild": "^0.20.0",
    "ovsx": "^0.9.0",
    "typescript": "^5.3.0"
  }
}
