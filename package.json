{
  "name": "vibeflow-ext",
  "displayName": "VibeFlow — AI Workflow Builder",
  "description": "Describe workflows in plain English. AI builds, runs, and self-heals Python automation scripts. By Virgil Junior Adoleyine 🇬🇭",
  "version": "2.0.0",
  "publisher": "VirgilAdoleyine",
  "icon": "media/icon.png",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["AI", "Machine Learning", "Other"],
  "keywords": ["workflow", "automation", "ai", "claude", "gemini", "python", "langchain", "vibeflow-ext"],
  "repository": {
    "type": "git",
    "url": "https://github.com/VirgilAdoleyine/vibeflow-ext-extension"
  },
  "activationEvents": ["onCommand:vibeflow-ext-ext.open", "onStartupFinished"],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "vibeflow-ext.open",
        "title": "VibeFlow: Open Workflow Builder",
        "icon": "$(zap)"
      },
      {
        "command": "vibeflow-ext.newWorkflow",
        "title": "VibeFlow: New Workflow from Prompt"
      },
      {
        "command": "vibeflow-ext.searchModels",
        "title": "VibeFlow: Search Best AI Models for Task"
      },
      {
        "command": "vibeflow-ext.checkRegulations",
        "title": "VibeFlow: Check Workflow Regulations"
      },
      {
        "command": "vibeflow-ext.generateFiles",
        "title": "VibeFlow: Generate .py + .env.local + README"
      },
      {
        "command": "vibeflow-ext.syncRepos",
        "title": "VibeFlow: Sync Cloud + Community Repos"
      },
      {
        "command": "vibeflow-ext.contributeRegGuard",
        "title": "VibeFlow: Contribute to RegGuard ⭐"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "vibeflow-ext.open",
          "group": "navigation",
          "when": "resourceExtname == .py || resourceExtname == .ts"
        }
      ]
    },
    "configuration": {
      "title": "VibeFlow",
      "properties": {
        "vibeflow-ext.openRouterKey": {
          "type": "string",
          "description": "Your OpenRouter API key. Get one at openrouter.ai",
          "secret": true
        },
        "vibeflow-ext.defaultModel": {
          "type": "string",
          "default": "anthropic/claude-sonnet-4-5",
          "description": "Default AI model (searched via Perplexity)"
        },
        "vibeflow-ext.perplexityKey": {
          "type": "string",
          "description": "Perplexity API key for model search + regulation scanning",
          "secret": true
        },
        "vibeflow-ext.e2bApiKey": {
          "type": "string",
          "description": "E2B sandbox API key",
          "secret": true
        },
        "vibeflow-ext.composioApiKey": {
          "type": "string",
          "description": "Composio API key for 400+ OAuth integrations",
          "secret": true
        },
        "vibeflow-ext.inngestSigningKey": {
          "type": "string",
          "description": "Inngest signing key",
          "secret": true
        },
        "vibeflow-ext.inngestEventKey": {
          "type": "string",
          "description": "Inngest event key",
          "secret": true
        },
        "vibeflow-ext.neonDatabaseUrl": {
          "type": "string",
          "description": "Neon Postgres database URL",
          "secret": true
        },
        "vibeflow-ext.upstashRedisUrl": {
          "type": "string",
          "description": "Upstash Redis URL",
          "secret": true
        },
        "vibeflow-ext.upstashRedisToken": {
          "type": "string",
          "description": "Upstash Redis token",
          "secret": true
        },
        "vibeflow-ext.userGitHubRepo": {
          "type": "string",
          "description": "Your personal/cloud GitHub repo URL (origin)"
        },
        "vibeflow-ext.communityGitRepo": {
          "type": "string",
          "description": "VibeFlow community repo URL"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.config.mjs --production && cd webview && npm run build",
    "watch": "node esbuild.config.mjs --watch",
    "watch:webview": "cd webview && npm run dev",
    "lint": "eslint src --ext ts",
    "package": "vsce package",
    "publish": "vsce publish && ovsx publish"
  },
  "dependencies": {
    "@langchain/openai": "^0.3.0",
    "langchain": "^0.3.0",
    "node-fetch": "^3.3.2",
    "simple-git": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.24.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0",
    "ovsx": "^0.9.0"
  }
}
