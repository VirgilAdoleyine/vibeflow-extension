# VibeFlow Extension Environment Variables
# Copy this file to .env and fill in your actual keys.
# DO NOT commit .env to version control.

# Core AI Keys
VIBEFLOW_OPENROUTER_KEY=your_openrouter_key_here
VIBEFLOW_PERPLEXITY_KEY=your_perplexity_key_here
VIBEFLOW_DEFAULT_MODEL=anthropic/claude-sonnet-4-5

# Integration Keys
VIBEFLOW_E2B_API_KEY=your_e2b_key_here
VIBEFLOW_COMPOSIO_API_KEY=your_composio_key_here

# Backend / Database Keys
VIBEFLOW_INNGEST_SIGNING_KEY=signkey-prod-ff6673279c52a62b8b7e881cbef5e45cab49c7d2dceb2bb6ff1214f753254063
VIBEFLOW_INNGEST_EVENT_KEY=3lq6wliJ-09aaidTPJ0eg9geG8tvKyZtWX1viDc1HK0swbXKymAVpwSvjCw0AL9Q5q44OqTgM39TcxAx2WpPOw
VIBEFLOW_NEON_DATABASE_URL=postgresql://user:pass@host/db
VIBEFLOW_UPSTASH_REDIS_URL=your_upstash_url
VIBEFLOW_UPSTASH_REDIS_TOKEN=your_upstash_token

# Git / Sync Keys
VIBEFLOW_USER_GITHUB_REPO=https://github.com/your-username/your-vibeflow-cloud-repo
VIBEFLOW_COMMUNITY_GIT_REPO=https://github.com/VirgilAdoleyine/vibeflow
